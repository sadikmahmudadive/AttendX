rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection rules
    // - regular users can read/write their own document but may not alter their role
    // - admins can read every user document (used by the admin dashboard)
    match /users/{userId} {
      allow read: if request.auth != null &&
                  (request.auth.uid == userId ||
                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");

      // Allow create (registration) — role must be "user"
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.role == "user";

      // Allow update own profile, but not role change
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.role == resource.data.role;
    }

    // Releases: any authenticated user can read; only admin can write
    match /releases/{releaseId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null
                  && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Custom build requests: anyone may create a request; only admin may read/write
    match /requests/{reqId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null
                  && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
  }
}
